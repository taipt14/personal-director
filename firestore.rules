rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for UserConfig
    function isValidUserConfig(data) {
      return data.userId == request.auth.uid
        && data.folders is list
        && data.appearance is map
        && data.appearance.theme in ['light', 'dark', 'glass']
        && data.keys().hasAll(['folders', 'appearance', 'userId', 'updatedAt'])
        && data.keys().size() == 4;
    }

    match /users/{userId} {
      allow get: if isValidId(userId) && isOwner(userId);
      
      allow create: if isValidId(userId) && isOwner(userId) 
        && isValidUserConfig(incoming())
        && incoming().updatedAt == request.time;
      
      allow update: if isValidId(userId) && isOwner(userId)
        && isValidUserConfig(incoming())
        && incoming().userId == existing().userId
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['folders', 'appearance', 'updatedAt']);
      
      allow delete: if isValidId(userId) && isOwner(userId);
    }
  }
}
