rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if true;
    }

    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for UserConfig
    function isValidUserConfig(data) {
      return data.userId == request.auth.uid
        && data.folders is list
        && data.appearance is map
        && data.appearance.theme in ['light', 'dark', 'glass']
        && data.keys().hasAll(['folders', 'appearance', 'userId', 'updatedAt'])
        && data.keys().size() == 4;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    // Default configuration for public access
    match /configs/public {
      allow read, write: if true;
    }
  }
}
